# Server
APP_HOST=0.0.0.0
APP_PORT=8383

# Facebook
FB_VERIFY_TOKEN=my_secret_verify_token
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
FB_GRAPH_API_VERSION=v21.0

# AI Provider: "openai" | "gemini" | "ollama"
AI_PROVIDER=ollama
AI_MODEL=llama3.2
AI_TIMEOUT=30
AI_SYSTEM_PROMPT=Bạn là trợ lý ảo của Luniva Studio. Trả lời ngắn gọn, thân thiện, bằng tiếng Việt.

# OpenAI (dùng khi AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Gemini (dùng khi AI_PROVIDER=gemini)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx
# AI_MODEL=gemini-2.0-flash

# Ollama (dùng khi AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.2

# Logging
LOG_LEVEL=INFO
